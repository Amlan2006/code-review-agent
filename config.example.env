HOST=0.0.0.0
PORT=8080

# GitHub webhook secret. Configure the same value in repository settings.
GITHUB_WEBHOOK_SECRET=change-me

# Repository checkout settings.
# If REPOSITORY_URL is empty, the clone URL from the webhook payload is used.
REPOSITORY_URL=
DEFAULT_BRANCH=main
DATA_DIR=./data

# Path inside the checked-out repository.
SOURCE_OF_TRUTH_FILE=SOURCE_OF_TRUTH.md

# Codex CLI settings.
CODEX_BIN=codex
CODEX_MODEL=
CODEX_TIMEOUT_SECONDS=900
MAX_PRIOR_REPORTS=8

# Telegram bot settings.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
